{
  "name": "siatech-ble-updater",
  "version": "2.0.2",
  "description": "Update your ComHAND remotes and receivers wirelessly.",
  "displayName": "ComHAND Updater",
  "repository": {
    "type": "git",
    "url": "https://github.com/siatech/siatech-ble-updater.git"
  },
  "author": "Nordic Semiconductor ASA",
  "license": "SEE LICENSE IN LICENSE",
  "main": "dist/bundle.js",
  "engines": {
    "nrfconnect": "^3.8.0"
  },
  "scripts": {
    "build": "nrfconnect-scripts build-prod",
    "clean-dist": "rimraf dist",
    "clean-modules": "rimraf \"node_modules/!(rimraf|.bin)\"",
    "clean": "npm run clean-dist && npm run clean-modules",
    "dev": "nrfconnect-scripts build-watch",
    "lint": "nrfconnect-scripts lint lib index.jsx",
    "lint-fix": "nrfconnect-scripts lint lib index.jsx --fix",
    "nordic-publish": "nrfconnect-scripts nordic-publish -s test",
    "test-watch": "nrfconnect-scripts test --watch",
    "test": "nrfconnect-scripts test",
    "webpack": "nrfconnect-scripts build-dev",
    "pack-prod": "nrfconnect-scripts build-prod && npm pack"
  },
  "files": [
    "dist/",
    "resources/icon.*",
    "icon.png",
    "LICENSE"
  ],
  "devDependencies": {
    "change-case": "^4.1.0",
    "chart.js": "^2.9.3",
    "immutable": "^3.8.2",
    "jquery": "^3.4.1",
    "lodash.throttle": "^4.1.1",
    "mousetrap": "^1.6.3",
    "pc-nrfconnect-shared": "github:NordicSemiconductor/pc-nrfconnect-shared#v5.10.0",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "react-onclickoutside": "^6.9.0",
    "react-redux": "7.2.0",
    "react-textarea-autosize": "^7.1.2",
    "uuid-v4": "^0.1.0"
  },
  "dependencies": {
    "@types/react": "^17.0.37",
    "@reduxjs/toolkit": "^1.5.1",
    "bluetooth-numbers-database": "github:NordicSemiconductor/bluetooth-numbers-database#75bb6a8079",
    "electron": "^13.5.2",
    "electron-store": "^6.0.0"
  },
  "bundleDependencies": [
    "bluetooth-numbers-database",
    "electron-store",
    "@reduxjs/toolkit"
  ],
  "eslintConfig": {
    "extends": "./node_modules/pc-nrfconnect-shared/config/eslintrc.json"
  },
  "prettier": "./node_modules/pc-nrfconnect-shared/config/prettier.config.js"
}
